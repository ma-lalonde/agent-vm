# Copy this file to .env and adjust for your setup, then run
# ./provision-agent-vm.sh. The script refuses to run without a .env
# present, so nothing runs against silently-assumed defaults.

# Name of the Incus VM.
VM_NAME=agent-vm

# Local image alias the base image is cached under (so re-runs don't
# re-download it every time).
BASE_IMAGE_ALIAS=agent-vm-base

# Upstream image to cache. images:debian/13/cloud ships cloud-init +
# incus-agent preinstalled, which is why it's the default -- other cloud
# images may need extra setup for `incus exec` to work on first boot.
BASE_IMAGE_REMOTE=images:debian/13/cloud

# VM resources.
VM_CPU=4
VM_MEMORY=8GiB
VM_DISK=40GiB

# Incus storage pool the VM's root disk is created on.
VM_STORAGE_POOL=default

# Host path shared into the VM via virtiofs. This is the directory that
# actually exists on your host filesystem.
WORKSPACE_SRC=/path/to/whatever/you/want/shared

# Mount point that path appears at inside the guest. This is a VM-local
# path -- it does not need to match WORKSPACE_SRC's name or location.
WORKSPACE_DEST=/mnt/workspace

# Where the dedicated SSH keypair for reaching the VM is generated
# (created on first run if it doesn't already exist).
SSH_KEY_PATH=${HOME}/.ssh/agent_vm_ed25519

# Name the host is added under as an Incus remote from inside the VM, if
# you use the remote-API feature (see README.md).
REMOTE_NAME=host

# Optional. A GitHub token used to authenticate `gh` (and, via `gh auth
# setup-git`, git's own credential helper) inside the VM during
# provisioning, so the agent can read GitHub without a manual `gh auth
# login` -- which is blocked for the agent afterward anyway (see
# guard-hook.py's GH_WRITE_CHAINS). Strongly recommend a fine-grained PAT
# (github.com Settings > Developer settings > Fine-grained tokens) scoped
# to the specific repos you want readable, with each permission set to
# Read-only (Contents, Metadata, Pull requests, Issues, etc.) -- that makes
# read-only a property of the token itself, not just of the guard hook's
# blocklist. Classic PATs can't do this for private repos: their `repo`
# scope is inherently read+write. Leave empty to skip gh/git auth entirely.
GH_TOKEN=

# Optional. Installs github.com/Mibayy/token-savior (verified: 1.1k
# stars, actively maintained MCP server) as a user-scoped MCP server, so
# the agent has a structural code-navigation/memory tool instead of the
# raw grep/find/Glob primitives the guard hook's deny list blocks (same
# policy as the host's own CLAUDE.md). NOT the same project as
# github.com/awesomo913/Claude-Token-Saver (an unrelated, much smaller,
# similarly-named repo) -- don't substitute one for the other.
INSTALL_TOKEN_SAVIOR=0

# Optional. Installs github.com/JuliusBrussee/caveman (verified: 85.7k
# stars, 4.7k forks via the GitHub API) as a Claude Code plugin, via
# Claude Code's own first-party plugin-marketplace mechanism -- NOT via
# the project's own `curl | bash` installer, which auto-detects and
# modifies every agent's config on the machine (broader than needed
# here). Makes agent output terser.
INSTALL_CAVEMAN=0

# Optional. Bridges github.com/tobi/qmd (@tobilu/qmd) into the VM as an
# MCP server -- semantic + BM25 search with no per-line size limit (unlike
# token-savior, which chokes on lines over ~100k chars). Runs as a daemon
# ON THE HOST, not installed in the VM: qmd's embedding model needs a GPU
# for reasonable speed and this VM deliberately has none. Requires `qmd`
# already installed and working on the host (this does not install qmd
# itself, only starts its HTTP server and points the VM at it). Complements
# token-savior rather than replacing it.
INSTALL_QMD_REMOTE=0

# Port qmd's HTTP MCP server binds to on the host (bridge-local IP only --
# there is no authentication on this transport, confirmed against its own
# docs, so it must never be exposed beyond the Incus bridge).
QMD_HTTP_PORT=8181
