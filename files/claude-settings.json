{
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Glob",
      "Grep",
      "Bash(grep:*)",
      "Bash(egrep:*)",
      "Bash(fgrep:*)",
      "Bash(rg:*)",
      "Bash(ag:*)",
      "Bash(ack:*)",
      "Bash(tac:*)",
      "Bash(awk:*)",
      "Bash(gawk:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(fdfind:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Bash(pkexec:*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git reset --merge*)",
      "Bash(git reset --keep*)",
      "Bash(git rebase*)",
      "Bash(git commit --amend*)",
      "Bash(git cherry-pick*)",
      "Bash(git revert --no-commit*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref*)",
      "Bash(git replace*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d --force*)",
      "Bash(git branch --delete --force*)",
      "Bash(git tag -d*)",
      "Bash(git tag --delete*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git prune*)",
      "Bash(git checkout --orphan*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf ./.git*)",
      "Edit(./.git/**)",
      "Write(./.git/**)",
      "Bash(git remote set-url*)",
      "Bash(git remote add*)",
      "Bash(git remote remove*)",
      "Bash(git remote rm*)",
      "Bash(git remote rename*)",
      "Bash(git config*remote.*)",
      "Bash(git config*push.*)",
      "Bash(git config*url.*)",
      "Bash(git config*credential.*)",
      "Bash(git symbolic-ref*)",
      "Bash(git fast-import*)",
      "Bash(gh api*-X DELETE*)",
      "Bash(gh api*-X PATCH*)",
      "Bash(gh api*-X PUT*)",
      "Bash(gh api*--method DELETE*)",
      "Bash(gh api*--method PATCH*)",
      "Bash(gh api*--method PUT*)",
      "Bash(gh release delete*)",
      "Bash(gh release edit*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo edit*)",
      "Bash(gh repo archive*)",
      "Bash(gh repo rename*)",
      "Bash(gh repo transfer*)",
      "Bash(gh ref delete*)",
      "Bash(gh auth login*)",
      "Bash(gh auth logout*)",
      "Bash(gh auth refresh*)",
      "Bash(gh auth setup-git*)",
      "Bash(gh secret*)",
      "Bash(gh variable*)",
      "Bash(gh workflow disable*)",
      "Bash(gh workflow enable*)",
      "Bash(gh workflow run*)",
      "Bash(curl*api.github.com*)",
      "Bash(curl*://github.com*)",
      "Bash(wget*github.com*)",
      "Bash(chattr*)",
      "Bash(bash -c*)",
      "Bash(sh -c*)",
      "Bash(zsh -c*)",
      "Bash(tee*.claude*)",
      "Bash(cp*.claude*)",
      "Bash(mv*.claude*)",
      "Bash(ln*.claude*)",
      "Bash(rsync*.claude*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/guard/hook.py"
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "model": "sonnet"
}
